proxmox = {
  endpoint    = "https://proxmox.example.com:8006/"
  api_token   = "terraform@pve!automation=your-token-here"
  insecure    = true
  node_name   = "pve01"
  template_id = 9100
}

vm_config = {
  count       = 1
  name_prefix = "debian-dev"
  cpu_cores   = 2
  memory_mb   = 2048
}

ansible_config = {
  run_after_create = true
}

tags = ["terraform", "debian", "dev"]
